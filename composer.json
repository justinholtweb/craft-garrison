    },
    "extra": {
        "handle": "garrison",
        "name": "Garrison",
        "developer": "justinholtweb",
        "developerUrl": "https://justinholt.com",
        "developerEmail": "justin@justinholtweb.com",
        "documentationUrl": "https://github.com/justinholtweb/craft-garrison",
        "changelogUrl": "https://raw.githubusercontent.com/justinholtweb/craft-garrison/main/CHANGELOG.md",
        "description": "Comprehensive security suite for Craft CMS — scanning, active protection, audit logging, and notifications.",
        "class": "justinholtweb\\garrison\\Plugin"
    }
