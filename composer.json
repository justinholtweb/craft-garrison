{
    "name": "justinholtweb/craft-garrison",
    "description": "Comprehensive security suite for Craft CMS — scanning, active protection, audit logging, and notifications.",
    "type": "craft-plugin",
    "license": "proprietary",
    "minimum-stability": "dev",
    "version": "5.1.4",
    "prefer-stable": true,
    "require": {
        "php": "^8.2",
        "craftcms/cms": "^5.0.0"
    },
    "require-dev": {
        "codeception/codeception": "^5.0",
        "craftcms/ecs": "dev-main",
        "craftcms/phpstan": "dev-main"
    },
    "autoload": {
        "psr-4": {
            "justinholtweb\\garrison\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "justinholtweb\\garrison\\tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "codecept run unit",
        "ecs": "ecs check",
        "ecs-fix": "ecs check --fix",
        "phpstan": "phpstan analyse"
    },
    "support": {
        "email": "justin@justinholt.com",
        "issues": "https://github.com/justinholtweb/craft-garrison/issues",
        "docs": "https://craft-garrison.com/docs"
    },
    "config": {
        "allow-plugins": {
            "craftcms/plugin-installer": true,
            "yiisoft/yii2-composer": true
        }
    },
    "extra": {
        "handle": "garrison",
        "name": "Garrison",
        "developer": "justinholtweb",
        "developerUrl": "https://justinholt.com",
        "developerEmail": "justin@justinholt.com",
        "documentationUrl": "https://craft-garrison.com/docs",
        "changelogUrl": "https://raw.githubusercontent.com/justinholtweb/craft-garrison/main/CHANGELOG.md",
        "description": "Comprehensive security suite for Craft CMS — scanning, active protection, audit logging, and notifications.",
        "class": "justinholtweb\\garrison\\Plugin"
    }
}
