    "description": "Comprehensive security suite for Craft CMS — scanning, active protection, audit logging, and notifications.",
    "version": "1.0.0",
    "type": "craft-plugin",
    "license": "proprietary",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.2",
        "craftcms/cms": "^5.0.0"
    },
    "require-dev": {
