{% extends 'garrison/_layouts/plugin' %}

{% set title = 'Audit Log'|t('garrison') %}
{% set selectedSubnavItem = 'sentinel' %}

{% set totalPages = (total / perPage)|round(0, 'ceil') %}

{% block pluginContent %}
    <p class="light">{{ '{total} recorded events.'|t('garrison', { total: total }) }}</p>

    {% if entries is empty %}
        <p class="light">{{ 'No audit events recorded yet.'|t('garrison') }}</p>
    {% else %}
        <table class="data fullwidth">
            <thead>
                <tr>
                    <th>{{ 'When'|t('garrison') }}</th>
                    <th>{{ 'Action'|t('garrison') }}</th>
                    <th>{{ 'Category'|t('garrison') }}</th>
                    <th>{{ 'User'|t('garrison') }}</th>
                    <th>{{ 'Target'|t('garrison') }}</th>
                    <th>{{ 'IP Address'|t('garrison') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for entry in entries %}
                    <tr>
                        <td>{{ entry.dateCreated|date('M j, Y g:i A') }}</td>
                        <td>{{ entry.action }}</td>
                        <td class="light">{{ entry.category }}</td>
                        <td>{{ entry.userName ?? '—' }}</td>
                        <td class="light">
                            {%- if entry.targetTitle -%}
                                {{ entry.targetTitle }}{% if entry.targetType %} <span class="light">({{ entry.targetType }})</span>{% endif %}
                            {%- else -%}—{%- endif -%}
                        </td>
                        <td><code>{{ entry.ipAddress ?? '—' }}</code></td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        {% if totalPages > 1 %}
            <div class="garrison-pagination" style="margin-top:16px;display:flex;gap:8px;align-items:center">
                {% if page > 1 %}
                    <a class="btn" href="{{ url('garrison/sentinel/audit-log', { page: page - 1 }) }}">{{ '← Previous'|t('garrison') }}</a>
                {% endif %}
                <span class="light">{{ 'Page {page} of {total}'|t('garrison', { page: page, total: totalPages }) }}</span>
                {% if page < totalPages %}
                    <a class="btn" href="{{ url('garrison/sentinel/audit-log', { page: page + 1 }) }}">{{ 'Next →'|t('garrison') }}</a>
                {% endif %}
            </div>
        {% endif %}
    {% endif %}
{% endblock %}

{% block actionButton %}
    <a href="{{ url('garrison/sentinel') }}" class="btn">{{ 'Back to Sentinel'|t('garrison') }}</a>
{% endblock %}
